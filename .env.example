PORT=8080
# Behind a reverse proxy (Render, nginx): set to 1 so rate limits use real client IP
# TRUST_PROXY=1
# Optional: hop count if you have multiple proxies (default 1)
# TRUST_PROXY_HOPS=1

# Rate limits (optional overrides)
# RATE_LIMIT_GLOBAL_MAX=800
# RATE_LIMIT_DISCOVERY_MAX=45
# RATE_LIMIT_KYC_MAX=20

# Discovery prep cache: cuts repeated Firestore reads for exclusions / incoming likes (per user)
# DISCOVERY_CACHE_TTL_MS=20000
# DISCOVERY_CACHE_MAX_ENTRIES=8000

# KYC: max parallel Human.js face runs per API instance (CPU protection)
# KYC_MAX_CONCURRENT=2

# Must match project_id in app/android/app/google-services.json (e.g. dapp-79473)
GCLOUD_PROJECT=dapp-79473
# Use the bucket id from Firebase Console → Storage (Files tab URL / settings). Often:
#   dapp-79473.appspot.com
# If unset, KYC tries both .appspot.com and .firebasestorage.app automatically.
# FIREBASE_STORAGE_BUCKET=dapp-79473.appspot.com

# Local: service-account.json in this folder (gitignored), or:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Render: paste full JSON as one line (Secret) — same project as the app
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"dapp-79473",...}

# Optional: skip face gender check in local dev (approve all selfies)
# KYC_DEV_APPROVE=1
