rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User profiles — own doc only for writes; authenticated read for discovery UIs
    // (tighten reads later e.g. only profileComplete users if you add public profile pages).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }
  }
}
